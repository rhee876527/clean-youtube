Subject: [PATCH] update JS lint config

---
 jsconfig.json | 11 +++++++----
 1 file changed, 7 insertions(+), 4 deletions(-)

diff --git a/jsconfig.json b/jsconfig.json
index 834a9ea..d628372 100644
--- a/jsconfig.json
+++ b/jsconfig.json
@@ -1,9 +1,12 @@
 {
 	"compilerOptions": {
 		"target": "esnext",
-		"module": "esnext",
+		"module": "Node16",
+		"moduleResolution": "node16",
+		"allowSyntheticDefaultImports": true,
 		"checkJs": true,
-		"moduleResolution": "node",
-		"allowSyntheticDefaultImports": true
+
+		"noImplicitAny": false,
+		"strict": false
 	}
-}
+}
\ No newline at end of file
